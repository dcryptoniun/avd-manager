{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AVD Manager",
  "version": "1.0.1",
  "identifier": "com.avdmanager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AVD Manager",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/dcryptoniun/avd-manager/releases/download/v{{current_version}}/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE0QkYzQTMwNTlDMjA0MTQKUldRVUJNSlpNRHEvcEhma0x2cS9KZVlEZHNWZlhLOGd0T0RVUU9sYU0wN0taZGlQSWp0VHRwRUwK"
    }
  }
}
